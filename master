  return (
    <div style={{ minHeight: "100vh", background: C.bg, display: "flex", alignItems: "center", justifyContent: "center", fontFamily: "'Segoe UI', sans-serif" }}>
      <div style={{ width: 400, maxWidth: "90vw", padding: 40, background: C.surface, borderRadius: 20, border: "1px solid " + C.border }}>
        <div style={{ textAlign: "center", marginBottom: 32 }}>
          <div style={{ fontSize: 36, fontWeight: 800, background: "linear-gradient(135deg, " + C.primary + ", " + C.accent + ")", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>
            AI QUEST
          </div>
          <p style={{ color: C.textSecondary, fontSize: 14, marginTop: 8 }}>인공지능 지식 도전</p>
        </div>

        <div style={{ display: "flex", marginBottom: 24, background: C.card, borderRadius: 10, padding: 3 }}>
          {["login", "signup"].map(function(m) {
            return (
              <div key={m} onClick={function() { setMode(m); setErr(""); }}
                style={{
                  flex: 1, textAlign: "center", padding: "10px 0", borderRadius: 8, cursor: "pointer", fontSize: 14, fontWeight: 600,
                  background: mode === m ? C.primary : "transparent", color: mode === m ? "#fff" : C.textSecondary, transition: "all .2s"
                }}>
                {m === "login" ? "로그인" : "회원가입"}
              </div>
            );
          })}
        </div>

        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          {mode === "signup" && (
            <input placeholder="닉네임" value={username} onChange={function(e) { setUsername(e.target.value); }}
              style={inputStyle} onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
          )}
          <input placeholder="아이디" value={id} onChange={function(e) { setId(e.target.value); }}
            style={inputStyle} onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
          <input placeholder="비밀번호" type="password" value={pw} onChange={function(e) { setPw(e.target.value); }}
            style={inputStyle} onKeyDown={function(e) { if (e.key === "Enter") handleSubmit(); }}
            onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
        </div>

        {err && <div style={{ color: C.danger, fontSize: 13, marginTop: 12, textAlign: "center" }}>{err}</div>}

        <button onClick={handleSubmit} style={{
          width: "100%", padding: "14px 0", marginTop: 20, border: "none", borderRadius: 10,
