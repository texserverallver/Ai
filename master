function AuthScreen({ onLogin }) {
  const [mode, setMode] = useState("login");
  const [id, setId] = useState("");
  const [pw, setPw] = useState("");
  const [username, setUsername] = useState("");
  const [err, setErr] = useState("");

  const handleSubmit = () => {
    if (!id.trim() || !pw.trim()) return setErr("아이디와 비밀번호를 입력해주세요.");
    const users = getUsers();
    if (mode === "signup") {
      if (!username.trim()) return setErr("닉네임을 입력해주세요.");
      if (users[id]) return setErr("이미 존재하는 아이디입니다.");
      if (pw.length < 4) return setErr("비밀번호는 4자 이상이어야 합니다.");
      const data = { pw: pw, username: username, clearedStages: [], perfectStages: [], achievements: [], speedClear: false, retryClears: 0, maxStreak: 0, failedStages: [], currentStreak: 0 };
      saveUser(id, data);
      onLogin(id, data);
    } else {
      if (!users[id]) return setErr("존재하지 않는 아이디입니다.");
      if (users[id].pw !== pw) return setErr("비밀번호가 틀립니다.");
