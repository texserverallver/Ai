// ─── Play Page ──────────────────────────────────────────────────────────────
function PlayPage({ stageId, user, updateUser, checkAchievements, setPage, goToStage }) {
  const stage = STAGES.find(function(s) { return s.id === stageId; });
  const [qi, setQi] = useState(0);
  const [score, setScore] = useState(0);
  const [selected, setSelected] = useState(null);
  const [showResult, setShowResult] = useState(false);
  const [finished, setFinished] = useState(false);
  const startTimeRef = useRef(Date.now());

  useEffect(function() {
    setQi(0);
    setScore(0);
    setSelected(null);
    setShowResult(false);
    setFinished(false);
    startTimeRef.current = Date.now();
  }, [stageId]);

  if (!stage) return React.createElement("div", null, "스테이지를 찾을 수 없습니다.");

  const q = stage.questions[qi];
  const total = stage.questions.length;
  const isCorrect = selected === q.answer;

  const handleSelect = function(idx) {
    if (showResult) return;
    setSelected(idx);
    setShowResult(true);

    const newScore = idx === q.answer ? score + 1 : score;
    if (idx === q.answer) setScore(newScore);

    setTimeout(function() {
      if (qi + 1 < total) {
        setQi(qi + 1);
        setSelected(null);
        setShowResult(false);
      } else {
        const elapsed = (Date.now() - startTimeRef.current) / 1000;
        const passed = newScore >= Math.ceil(total * 0.6);
        const perfect = newScore === total;
        const wasFailed = (user.failedStages || []).includes(stageId);

        const updates = {};
        Object.keys(user).forEach(function(k) { updates[k] = user[k]; });

        if (passed && !(user.clearedStages || []).includes(stageId)) {
          updates.clearedStages = (user.clearedStages || []).concat([stageId]);
          updates.currentStreak = (user.currentStreak || 0) + 1;
          updates.maxStreak = Math.max(updates.currentStreak, user.maxStreak || 0);
        }
        if (!passed) {
          const fs = (user.failedStages || []).slice();
          if (fs.indexOf(stageId) === -1) fs.push(stageId);
          updates.failedStages = fs;
          updates.currentStreak = 0;
        }
        if (perfect) {
          const ps = (user.perfectStages || []).slice();
          if (ps.indexOf(stageId) === -1) ps.push(stageId);
          updates.perfectStages = ps;
        }
        if (elapsed < 60 && passed) updates.speedClear = true;
        if (passed && wasFailed) updates.retryClears = (user.retryClears || 0) + 1;

        updates.achievements = checkAchievements(updates);
        var id = updates.id;
        var rest = {};
        Object.keys(updates).forEach(function(k) { if (k !== "id") rest[k] = updates[k]; });
        updateUser(rest);
        setFinished({ passed: passed, score: newScore, total: total, perfect: perfect, elapsed: elapsed });
      }
    }, 1200);
  };

  if (finished) {
    const nextId = stageId + 1;
    const hasNext = nextId <= STAGES.length;
    return (
      <div style={{ animation: "fadeIn .4s ease", textAlign: "center", paddingTop: 40 }}>
        <div style={{ fontSize: 64, marginBottom: 16 }}>{finished.passed ? (finished.perfect ? "\u{1F451}" : "\u{1F389}") : "\u{1F622}"}</div>
        <h2 style={{ fontSize: 28, fontWeight: 800, marginBottom: 8, color: C.textPrimary }}>
          {finished.passed ? (finished.perfect ? "퍼펙트 클리어!" : "스테이지 클리어!") : "아쉽네요..."}
        </h2>
        <p style={{ color: C.textSecondary, fontSize: 15, marginBottom: 28 }}>
          {finished.score} / {finished.total} 정답 ({Math.round(finished.elapsed)}초)
          {!finished.passed && <React.Fragment><br />60% 이상 정답 시 클리어됩니다</React.Fragment>}
        </p>

        <div style={{ display: "flex", gap: 12, justifyContent: "center", flexWrap: "wrap" }}>
          {!finished.passed && (
            <Btn onClick={function() { setQi(0); setScore(0); setSelected(null); setShowResult(false); setFinished(false); startTimeRef.current = Date.now(); }}
              bg={C.primary} label="다시 도전" />
          )}
          {finished.passed && hasNext && (
            <Btn onClick={function() { goToStage(nextId); }} bg={C.accent} color={C.bg} label={"스테이지 " + nextId + " →"} />
          )}
          <Btn onClick={function() { setPage("stages"); }} bg={C.card} border={C.border} label="스테이지 목록" />
          <Btn onClick={function() { setPage("main"); }} bg={C.card} border={C.border} label="메인으로" />
        </div>
      </div>
    );
  }

  return (
    <div style={{ animation: "fadeIn .3s ease" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 24 }}>
        <div>
          <div style={{ fontSize: 13, color: C.accent, fontWeight: 600 }}>Stage {stage.id}</div>
          <div style={{ fontSize: 20, fontWeight: 700 }}>{stage.title}</div>
        </div>
        <div style={{ fontSize: 14, color: C.textSecondary, fontWeight: 600 }}>
          {qi + 1} / {total}
        </div>
      </div>

      <div style={{ height: 4, background: C.bg, borderRadius: 2, marginBottom: 32 }}>
        <div style={{ height: "100%", width: ((qi + 1) / total) * 100 + "%", background: "linear-gradient(90deg, " + C.primary + ", " + C.accent + ")", borderRadius: 2, transition: "width .3s" }} />
      </div>

      <div style={{ background: C.card, border: "1px solid " + C.border, borderRadius: 16, padding: 28, marginBottom: 20 }}>
        <div style={{ fontSize: 11, color: C.textDim, fontWeight: 600, marginBottom: 12, letterSpacing: 1 }}>QUESTION {qi + 1}</div>
        <div style={{ fontSize: 18, fontWeight: 600, lineHeight: 1.6 }}>{q.q}</div>
      </div>

      <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
        {q.options.map(function(opt, idx) {
          var bg = C.card, bdr = C.border, col = C.textPrimary;
          if (showResult) {
            if (idx === q.answer) { bg = C.accent + "22"; bdr = C.accent; col = C.accent; }
            else if (idx === selected && !isCorrect) { bg = C.danger + "15"; bdr = C.danger; col = C.danger; }
          } else if (selected === idx) {
            bg = C.primary + "18"; bdr = C.primary;
          }
          return (
            <div key={idx} onClick={function() { handleSelect(idx); }}
              style={{
                padding: "16px 20px", background: bg, border: "1px solid " + bdr,
                borderRadius: 12, cursor: showResult ? "default" : "pointer",
                fontSize: 15, color: col, transition: "all .2s", display: "flex", alignItems: "center", gap: 12
              }}>
              <span style={{
                width: 28, height: 28, borderRadius: 8, display: "flex", alignItems: "center", justifyContent: "center",
                background: showResult && idx === q.answer ? C.accent : showResult && idx === selected ? C.danger : C.primary + "22",
                color: showResult ? "#fff" : C.primary, fontSize: 13, fontWeight: 700, flexShrink: 0
              }}>
                {showResult && idx === q.answer ? "\u2713" : showResult && idx === selected ? "\u2717" : String.fromCharCode(65 + idx)}
              </span>
              {opt}
            </div>
          );
        })}
      </div>

      {showResult && (
        <div style={{ marginTop: 16, padding: "14px 20px", borderRadius: 10, fontSize: 14, fontWeight: 600, textAlign: "center",
          background: isCorrect ? C.accent + "15" : C.danger + "15",
          color: isCorrect ? C.accent : C.danger
        }}>
          {isCorrect ? "정답입니다! \u{1F389}" : "오답입니다. 정답: " + q.options[q.answer]}
        </div>
      )}
    </div>
  );
}

