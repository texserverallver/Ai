// ─── Profile Page ───────────────────────────────────────────────────────────
function ProfilePage({ user, updateUser }) {
  const [newUsername, setNewUsername] = useState(user.username || "");
  const [newPw, setNewPw] = useState("");
  const [confirmPw, setConfirmPw] = useState("");
  const [msg, setMsg] = useState("");

  const handleSaveName = function() {
    if (!newUsername.trim()) return setMsg("닉네임을 입력해주세요.");
    updateUser({ username: newUsername.trim() });
    const users = getUsers();
    users[user.id].username = newUsername.trim();
    saveUsers(users);
    setMsg("닉네임이 변경되었습니다!");
    setTimeout(function() { setMsg(""); }, 2000);
  };

  const handleSavePw = function() {
    if (!newPw || !confirmPw) return setMsg("비밀번호를 입력해주세요.");
    if (newPw.length < 4) return setMsg("비밀번호는 4자 이상이어야 합니다.");
    if (newPw !== confirmPw) return setMsg("비밀번호가 일치하지 않습니다.");
    const users = getUsers();
    users[user.id].pw = newPw;
    saveUsers(users);
    setNewPw(""); setConfirmPw("");
    setMsg("비밀번호가 변경되었습니다!");
    setTimeout(function() { setMsg(""); }, 2000);
  };

  const inputStyle = {
    width: "100%", padding: "12px 16px", background: C.bg, border: "1px solid " + C.border,
    borderRadius: 10, color: C.textPrimary, fontSize: 14, outline: "none"
  };

  return (
    <div style={{ animation: "fadeIn .4s ease", maxWidth: 480 }}>
      <h2 style={{ fontSize: 24, fontWeight: 800, marginBottom: 28, color: C.textPrimary }}>프로필</h2>

      <div style={{ textAlign: "center", marginBottom: 32 }}>
        <div style={{
          width: 80, height: 80, borderRadius: "50%", margin: "0 auto 12px",
          background: "linear-gradient(135deg, " + C.primary + ", " + C.accent + ")",
          display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: 32, fontWeight: 700, color: "#fff"
        }}>
          {(user.username || user.id)[0].toUpperCase()}
        </div>
        <div style={{ fontSize: 18, fontWeight: 700 }}>{user.username || user.id}</div>
        <div style={{ fontSize: 13, color: C.textSecondary }}>ID: {user.id}</div>
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12, marginBottom: 28 }}>
        {[
          { label: "클리어", val: (user.clearedStages && user.clearedStages.length) || 0 },
          { label: "퍼펙트", val: (user.perfectStages && user.perfectStages.length) || 0 },
          { label: "업적", val: (user.achievements && user.achievements.length) || 0 },
        ].map(function(s) {
          return (
            <div key={s.label} style={{ textAlign: "center", padding: 16, background: C.card, borderRadius: 12, border: "1px solid " + C.border }}>
              <div style={{ fontSize: 24, fontWeight: 800, color: C.accent }}>{s.val}</div>
              <div style={{ fontSize: 12, color: C.textSecondary, marginTop: 4 }}>{s.label}</div>
            </div>
          );
        })}
      </div>

      <div style={{ background: C.card, borderRadius: 14, padding: 22, marginBottom: 16, border: "1px solid " + C.border }}>
        <div style={{ fontSize: 15, fontWeight: 700, marginBottom: 14 }}>닉네임 변경</div>
        <div style={{ display: "flex", gap: 10 }}>
          <input value={newUsername} onChange={function(e) { setNewUsername(e.target.value); }} style={Object.assign({}, inputStyle, { flex: 1 })}
            onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
          <button onClick={handleSaveName} style={{
            padding: "0 20px", border: "none", borderRadius: 10,
            background: C.primary, color: "#fff", fontWeight: 600, cursor: "pointer", fontSize: 14, whiteSpace: "nowrap"
          }}>변경</button>
        </div>
      </div>

      <div style={{ background: C.card, borderRadius: 14, padding: 22, border: "1px solid " + C.border }}>
        <div style={{ fontSize: 15, fontWeight: 700, marginBottom: 14 }}>비밀번호 변경</div>
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          <input placeholder="새 비밀번호" type="password" value={newPw} onChange={function(e) { setNewPw(e.target.value); }} style={inputStyle}
            onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
          <input placeholder="비밀번호 확인" type="password" value={confirmPw} onChange={function(e) { setConfirmPw(e.target.value); }} style={inputStyle}
            onFocus={function(e) { e.target.style.borderColor = C.primary; }} onBlur={function(e) { e.target.style.borderColor = C.border; }} />
          <button onClick={handleSavePw} style={{
            padding: "12px 0", border: "none", borderRadius: 10,
            background: C.primary, color: "#fff", fontWeight: 600, cursor: "pointer", fontSize: 14
          }}>비밀번호 변경</button>
        </div>
      </div>

      {msg && <div style={{
        marginTop: 16, padding: "12px 20px", borderRadius: 10, textAlign: "center",
        background: msg.indexOf("변경되었습니다") !== -1 ? C.accent + "15" : C.danger + "15",
        color: msg.indexOf("변경되었습니다") !== -1 ? C.accent : C.danger,
        fontSize: 14, fontWeight: 600
      }}>{msg}</div>}
    </div>
  );
}

// ─── Main App ───────────────────────────────────────────────────────────────
function App() {
  const [user, setUser] = useState(null);
  const [page, setPage] = useState("main");
  const [stageId, setStageId] = useState(null);
  const [popup, setPopup] = useState(null);
  const [profileMenu, setProfileMenu] = useState(false);
  const popupTimer = useRef(null);

  useEffect(function() {
    const sid = sessionStorage.getItem("ai_quiz_session");
    if (sid) {
      const users = getUsers();
      if (users[sid]) setUser(Object.assign({ id: sid }, users[sid]));
    }
  }, []);

  const login = function(id, data) {
    sessionStorage.setItem("ai_quiz_session", id);
    setUser(Object.assign({ id: id }, data));
  };

  const logout = function() {
    sessionStorage.removeItem("ai_quiz_session");
    setUser(null);
    setPage("main");
    setProfileMenu(false);
  };

  const updateUser = useCallback(function(updates) {
    setUser(function(prev) {
      const next = Object.assign({}, prev, updates);
      const rest = {};
      Object.keys(next).forEach(function(k) { if (k !== "id") rest[k] = next[k]; });
      saveUser(next.id, rest);
      return next;
    });
  }, []);

  const showAchievementPopup = useCallback(function(ach) {
    setPopup(ach);
    if (popupTimer.current) clearTimeout(popupTimer.current);
    popupTimer.current = setTimeout(function() { setPopup(null); }, 3500);
  }, []);

  const checkAchievements = useCallback(function(userData) {
    const prev = (userData.achievements || []).slice();
    ACHIEVEMENTS.forEach(function(a) {
      if (prev.indexOf(a.id) === -1 && a.condition(userData)) {
        prev.push(a.id);
        showAchievementPopup(a);
      }
    });
    return prev;
  }, [showAchievementPopup]);

  const goToStage = function(id) { setStageId(id); setPage("play"); };
  const currentStage = function() { return ((user && user.clearedStages && user.clearedStages.length) || 0) + 1; };

  const goToLastStage = function() {
    const cs = currentStage();
    if (cs <= STAGES.length) goToStage(cs);
    else setPage("stages");
  };

  if (!user) return React.createElement(AuthScreen, { onLogin: login });

  return (
    <div style={{ minHeight: "100vh", background: C.bg, color: C.textPrimary, fontFamily: "'Segoe UI', -apple-system, BlinkMacSystemFont, 'Malgun Gothic', sans-serif" }}>
      {/* Nav */}
      <nav style={{ background: C.surface, borderBottom: "1px solid " + C.border, padding: "0 20px", display: "flex", alignItems: "center", height: 60, position: "sticky", top: 0, zIndex: 100, gap: 0 }}>
        <div onClick={function() { setPage("main"); }} style={{ cursor: "pointer", display: "flex", alignItems: "center", gap: 8, marginRight: 32 }}>
          <span style={{ fontSize: 22, fontWeight: 800, background: "linear-gradient(135deg, " + C.primary + ", " + C.accent + ")", WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent" }}>AI QUEST</span>
        </div>
        <NavBtn active={page === "stages"} onClick={function() { setPage("stages"); }}>{"\u{1F4CB}"} 스테이지</NavBtn>
        <NavBtn onClick={goToLastStage}>{"\u{1F680}"} 바로가기</NavBtn>
        <NavBtn active={page === "achievements"} onClick={function() { setPage("achievements"); }}>{"\u{1F3C6}"} 업적</NavBtn>
        <div style={{ marginLeft: "auto", position: "relative" }}>
          <div onClick={function() { setProfileMenu(!profileMenu); }} style={{
            cursor: "pointer", width: 36, height: 36, borderRadius: "50%",
            background: "linear-gradient(135deg, " + C.primary + ", " + C.accent + ")",
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 16, fontWeight: 700, color: "#fff", userSelect: "none"
          }}>
            {(user.username || user.id)[0].toUpperCase()}
          </div>
          {profileMenu && (
            <div style={{
              position: "absolute", right: 0, top: 44, background: C.card,
              border: "1px solid " + C.border, borderRadius: 12, minWidth: 180,
              boxShadow: "0 8px 32px rgba(0,0,0,.4)", overflow: "hidden", zIndex: 200
            }}>
              <div onClick={function() { setPage("profile"); setProfileMenu(false); }}
                style={{ padding: "14px 20px", cursor: "pointer", fontSize: 14, borderBottom: "1px solid " + C.border, transition: "background .15s" }}
                onMouseEnter={function(e) { e.currentTarget.style.background = C.cardHover; }}
                onMouseLeave={function(e) { e.currentTarget.style.background = "transparent"; }}>
                {"\u{1F464}"} 프로필
              </div>
              <div onClick={logout}
                style={{ padding: "14px 20px", cursor: "pointer", fontSize: 14, color: C.danger, transition: "background .15s" }}
                onMouseEnter={function(e) { e.currentTarget.style.background = C.cardHover; }}
                onMouseLeave={function(e) { e.currentTarget.style.background = "transparent"; }}>
                {"\u{1F6AA}"} 로그아웃
              </div>
            </div>
          )}
        </div>
      </nav>

      {/* Achievement Popup */}
      {popup && (
        <div style={{
          position: "fixed", top: 80, left: "50%", transform: "translateX(-50%)",
          background: "linear-gradient(135deg, " + C.card + ", " + C.surface + ")",
          border: "2px solid " + C.gold, borderRadius: 16, padding: "20px 32px",
          zIndex: 999, display: "flex", alignItems: "center", gap: 16,
          boxShadow: "0 0 40px rgba(255, 215, 0, .25)",
          animation: "slideDown .4s ease"
        }}>
          <span style={{ fontSize: 40 }}>{popup.icon}</span>
          <div>
            <div style={{ fontSize: 11, color: C.gold, fontWeight: 700, letterSpacing: 2, textTransform: "uppercase" }}>업적 달성!</div>
            <div style={{ fontSize: 18, fontWeight: 700, marginTop: 2 }}>{popup.title}</div>
            <div style={{ fontSize: 13, color: C.textSecondary, marginTop: 2 }}>{popup.desc}</div>
          </div>
        </div>
      )}

      {/* Content */}
      <div style={{ maxWidth: 900, margin: "0 auto", padding: "32px 20px" }} onClick={function() { if (profileMenu) setProfileMenu(false); }}>
        {page === "main" && <MainPage user={user} goToStage={goToStage} goToLastStage={goToLastStage} setPage={setPage} />}
        {page === "stages" && <StagesPage user={user} goToStage={goToStage} />}
        {page === "achievements" && <AchievementsPage user={user} />}
        {page === "profile" && <ProfilePage user={user} updateUser={updateUser} />}
        {page === "play" && <PlayPage stageId={stageId} user={user} updateUser={updateUser} checkAchievements={checkAchievements} setPage={setPage} goToStage={goToStage} />}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(React.createElement(App));
</script>
</body>
</html>
